# ---- Maven / Java ----
# Build output
**/target/
**/out/

# Package files / compiled classes
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Maven wrapper (keep the scripts, ignore cache/dir artifacts)
.mvn/wrapper/
!mvnw
!mvnw.cmd

# Test reports and coverage
**/target/surefire-reports/
**/target/failsafe-reports/
**/target/site/
**/target/jacoco.exec
**/jacoco.exec

# Logs
*.log

# JVM crash logs
hs_err_pid*
replay_pid*

# ---- IDEs ----
# IntelliJ IDEA / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.project
.classpath
.settings/
.factorypath

# VS Code
.vscode/

# ---- OS files ----
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/

# ---- Misc ----
# Local environment / secrets (none expected, but future-proof)
*.env
.env.*

# Temporary files
*.swp
*.swo
*~
*.tmp
~$*

# Generated by tools
/.idea_modules/
/.metadata/

